# LLM provider (Phase 4) — copy to .env and fill in values
GROQ_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=60

# Hugging Face dataset (Phase 1)
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
DATA_CACHE_DIR=data/cache

# Recommendation pipeline defaults
TOP_K=5
SHORTLIST_MAX=20
MIN_RATING_DEFAULT=0.0
